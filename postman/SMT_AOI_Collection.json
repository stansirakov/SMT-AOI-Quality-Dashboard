          ],
          "request": {
            "method": "GET",
            "url": "{{base_url}}/api/board-master"
          }
        },
        {
          "name": "Create Board Master Entry",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 201 Created', function() {",
                  "    pm.response.to.have.status(201);",
                  "});",
                  "",
                  "pm.test('Response has id', function() {",
                  "    pm.expect(pm.response.json()).to.have.property('id');",
                  "});",
                  "",
                  "pm.test('Board key matches', function() {",
                  "    pm.expect(pm.response.json().board_key).to.eql('99999TEST');",
                  "});",
                  "",
                  "pm.test('Project matches', function() {",
                  "    pm.expect(pm.response.json().project).to.eql('TEST_PROJECT');",
                  "});",
