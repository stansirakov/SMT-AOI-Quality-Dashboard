{
  "info": {
    "name": "SMT AOI Quality Dashboard API",
    "description": "Complete API test collection for SMT AOI Quality Dashboard.\nIncludes positive and negative test cases for all endpoints.\n\nSetup:\n1. Import this collection in Postman\n2. Import the Environment file (SMT_AOI_Environment.json)\n3. Start the Flask app: python app.py\n4. Run 'Login as Admin' first to set the session cookie",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "_postman_id": "smt-aoi-dashboard-v1"
  },
  "variable": [
    {
      "key": "base_url",
      "value": "http://localhost:5000",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "01 - Authentication",
      "description": "Login, logout, session management and password change",
      "item": [
        {
          "name": "Login - Admin (Valid)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200 OK', function() {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test('Response has username', function() {",
                  "    var json = pm.response.json();",
                  "    pm.expect(json.username).to.eql('admin');",
                  "});",
                  "",
                  "pm.test('Response has role admin', function() {",
                  "    var json = pm.response.json();",
                  "    pm.expect(json.role).to.eql('admin');",
                  "});",
                  "",
                  "pm.test('Response has full_name', function() {",
                  "    var json = pm.response.json();",
                  "    pm.expect(json).to.have.property('full_name');",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"username\": \"admin\",\n    \"password\": \"admin123\"\n}"
            },
            "url": "{{base_url}}/api/auth/login"
          }
        },
        {
          "name": "Login - Editor (Valid)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200 OK', function() {",
