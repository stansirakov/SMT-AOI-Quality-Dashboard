              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"board_key\": \"99999TEST\",\n    \"project\": \"DUPLICATE_TEST\",\n    \"subboards\": 4\n}"
            },
            "url": "{{base_url}}/api/board-master"
