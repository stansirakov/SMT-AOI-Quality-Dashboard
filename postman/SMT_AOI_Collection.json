            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"board_key\": \"INCOMPLETE\"\n}"
            },
            "url": "{{base_url}}/api/board-master"
