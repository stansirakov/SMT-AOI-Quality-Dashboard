    {
      "name": "04 - Data & KPI",
      "description": "AOI raw data and KPI calculations",
      "item": [
        {
          "name": "Get All Data",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200 OK', function() {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test('Response has raw, lots, sessions', function() {",
                  "    var json = pm.response.json();",
                  "    pm.expect(json).to.have.all.keys('raw', 'lots', 'sessions');",
                  "});",
                  "",
                  "pm.test('raw is array', function() {",
                  "    pm.expect(pm.response.json().raw).to.be.an('array');",
                  "});",
                  "",
                  "pm.test('lots is array', function() {",
                  "    pm.expect(pm.response.json().lots).to.be.an('array');",
                  "});",
                  "",
                  "pm.test('Response time under 2000ms', function() {",
                  "    pm.expect(pm.response.responseTime).to.be.below(2000);",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "url": "{{base_url}}/api/data"
          }
        },
        {
          "name": "Get KPI Data",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200 OK', function() {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test('Response has kpis array', function() {",
                  "    pm.expect(pm.response.json().kpis).to.be.an('array');",
                  "});",
                  "",
                  "pm.test('Response has pareto data', function() {",
                  "    var json = pm.response.json();",
                  "    pm.expect(json).to.have.property('pareto_type');",
                  "    pm.expect(json).to.have.property('pareto_ref');",
                  "    pm.expect(json).to.have.property('pareto_project');",
                  "});",
                  "",
                  "if (pm.response.json().kpis.length > 0) {",
                  "    pm.test('KPI entry has required fields', function() {",
                  "        var k = pm.response.json().kpis[0];",
                  "        pm.expect(k).to.have.property('project');",
                  "        pm.expect(k).to.have.property('ppy_pct');",
                  "        pm.expect(k).to.have.property('fpy_pct');",
                  "        pm.expect(k).to.have.property('scrap_pct');",
                  "    });",
                  "",
                  "    pm.test('PPY between 0 and 100', function() {",
                  "        pm.response.json().kpis.forEach(function(k) {",
                  "            pm.expect(k.ppy_pct).to.be.within(0, 100);",
                  "        });",
                  "    });",
                  "",
                  "    pm.test('FPY between 0 and 100', function() {",
                  "        pm.response.json().kpis.forEach(function(k) {",
                  "            pm.expect(k.fpy_pct).to.be.within(0, 100);",
                  "        });",
                  "    });",
                  "",
                  "    pm.test('Scrap between 0 and 100', function() {",
                  "        pm.response.json().kpis.forEach(function(k) {",
                  "            pm.expect(k.scrap_pct).to.be.within(0, 100);",
                  "        });",
                  "    });",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "url": "{{base_url}}/api/kpi"
          }
        },
