            "body": {
              "mode": "raw",
              "raw": "{\n    \"problem\": \"[Postman Test] R1 Bridge recurring in 5 lots - Variant 12144846\",\n    \"action\": \"Adjust solder paste aperture by 10%\",\n    \"variant\": \"12144846\",\n    \"reference\": \"R1\",\n    \"defect_type\": \"Bridge\",\n    \"lots\": \"A04454, A04455\",\n    \"owner\": \"SMT Engineer\",\n    \"target_date\": \"2026-05-01\",\n    \"occurrences\": 5,\n    \"notes\": \"Created via Postman API test\"\n}"
            },
