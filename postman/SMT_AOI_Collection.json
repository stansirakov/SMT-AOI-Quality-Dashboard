              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"board_key\": \"99999TEST\",\n    \"project\": \"TEST_PROJECT\",\n    \"subboards\": 8,\n    \"pair\": \"\",\n    \"has_ict\": false,\n    \"has_depaneling\": false,\n    \"notes\": \"Test entry - can be deleted\"\n}"
            },
            "url": "{{base_url}}/api/board-master"
          }
        },
        {
          "name": "Create Board Master - Duplicate Key (Negative)",
          "event": [
            {
              "listen": "test",
              "script": {
